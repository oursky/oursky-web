---
/**
 * OurValueSection — "Why Oursky?" value cards + statistics.
 *
 * Webflow ref: .our-value-section + .statistics-container
 * Two side-by-side rounded cards: motto (gray-blue) + copy (dark blue).
 * 3-column grid of stats below.
 * Counter animation triggered on scroll via inline script.
 */

const stats = [
  { number: '15+', count: 13,  color: '#39c086', title: 'Years of web / app experiences', icon: 'M16 288c-11.4-19.8-11.4-44.2 0-64L108.3 64.2c11.4-19.8 32.6-32 55.4-32l184.6 0c22.9 0 44 12.2 55.4 32L496 224c11.4 19.8 11.4 44.2 0 64L403.7 447.8c-11.4 19.8-32.6 32-55.4 32l-184.6 0c-22.9 0-44-12.2-55.4-32L16 288zm27.7-48c-5.7 9.9-5.7 22.1 0 32L136 431.8c5.7 9.9 16.3 16 27.7 16l184.6 0c11.4 0 22-6.1 27.7-16L468.3 272c5.7-9.9 5.7-22.1 0-32L376 80.2c-5.7-9.9-16.3-16-27.7-16l-184.6 0c-11.4 0-22 6.1-27.7 16L43.7 240zm319.6-36.7l-128 128c-6.2 6.2-16.4 6.2-22.6 0l-64-64c-6.2-6.2-6.2-16.4 0-22.6s16.4-6.2 22.6 0L224 297.4 340.7 180.7c6.2-6.2 16.4-6.2 22.6 0s6.2 16.4 0 22.6z', viewBox: '0 0 512 512' },
  { number: '70+', count: 70,  color: '#146aff', title: 'Experts', icon: 'M104 88a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0A56 56 0 1 0 72 88a56 56 0 1 0 112 0zm8 88l-8 0-24 0-88 0-9.1 0-4.7 7.8-48 80-5.3 8.9 6 8.5L64 357l0 75 0 16 16 0 96 0 16 0 0-16 0-87.2L170.5 318 160 304.8 160 416l-64 0 0-208 64 0 0 64.9 8.7-12.4L192 227.2l0-35.2 0-16zM448 432l0 16 16 0 96 0 16 0 0-16 0-75 53.1-75.9 6-8.5-5.3-8.9-48-80-4.7-7.8-9.1 0-88 0-24 0-8 0 0 16 0 35.2 23.3 33.3 8.7 12.4 0-64.9 64 0 0 208-64 0 0-111.2L469.5 318 448 344.8l0 87.2zM43.1 271.3L64 236.4l0 64.8L43.1 271.3zM536 88a24 24 0 1 1 -48 0 24 24 0 1 1 48 0zm-80 0a56 56 0 1 0 112 0A56 56 0 1 0 456 88zM596.9 271.3L576 301.2l0-64.8 20.9 34.9z', viewBox: '0 0 640 512' },
  { number: '3+',  count: 3,   color: '#40afd4', title: 'Offices', subtitle: 'UK · TW · HK · JP', icon: 'M352 192c0-88.4-71.6-160-160-160S32 103.6 32 192c0 20.2 9.1 48.6 26.5 82.7c16.9 33.2 39.9 68.2 63.4 100.5c23.4 32.2 46.9 61 64.5 81.9c1.9 2.3 3.8 4.5 5.6 6.6c1.8-2.1 3.6-4.3 5.6-6.6c17.7-20.8 41.1-49.7 64.5-81.9c23.5-32.3 46.4-67.3 63.4-100.5C342.9 240.6 352 212.2 352 192zm32 0c0 88.8-120.7 237.9-170.7 295.9C200.2 503.1 192 512 192 512s-8.2-8.9-21.3-24.1C120.7 429.9 0 280.8 0 192C0 86 86 0 192 0S384 86 384 192z', viewBox: '0 0 384 512' },
  { number: '5m+', count: 5000000, color: '#2a97c6', title: 'Single app with most users', icon: 'M544 241.1l0-9.1c0-57.4-46.6-104-104-104c-13.4 0-26.2 2.5-37.9 7.1l-24.3 9.5-14.2-22C340.8 87.3 301.1 64 256 64c-70.7 0-128 57.3-128 128l0 8.2 0 22.6-21.3 7.5C63.1 245.8 32 287.3 32 336l0 112 112 0 368 0 96 0 0-96c0-35.5-19.2-66.5-48-83.2l-16-9.2 0-18.5z', viewBox: '0 0 640 512' },
  { number: '150+',count: 300, color: '#2a4b83', title: 'Projects Shipped', icon: 'M208 0L192 0l0 16 0 48-80 0L96 64l0 16 0 160 3.1 0L26.8 264.9l-23.3 8 16.8 18 112 120 23.4-21.8-95.2-102L272 214.4 272 384l0 16 32 0 0-16 0-169.6 211.5 72.7-95.2 102 23.4 21.8 112-120 16.8-18-23.3-8L476.9 240l3.1 0 0-160 0-16-16 0-80 0 0-48 0-16L368 0 208 0z', viewBox: '0 0 576 512' },
  { number: '8+',  count: 8,   color: '#e9a125', title: 'Featured on AppStore / Play Store', icon: 'M272 381.1l-.4-.1-2.3-.4c-34-6-100.6-27.8-159.1-74.4C51.2 259.2 0 186.5 0 80L0 64l16 0 113.6 0c-.5-10.3-.9-21-1.2-32c-.3-10.4-.4-21-.4-32l32 0L416 0l32 0c0 11-.1 21.6-.4 32c-.3 11-.7 21.7-1.2 32L560 64l16 0 0 16c0 106.5-51.2 179.2-110.2 226.1c-58.5 46.6-125.1 68.5-159.1 74.4l-2.3 .4-.4 .1 0 98.9 96 0 16 0 0 32-16 0-112 0-112 0-16 0 0-32 16 0 96 0 0-98.9z', viewBox: '0 0 576 512' },
];
---

<section class="w-full" aria-label="Why Oursky">
  <!-- Two-card row -->
  <div class="scroll-reveal-group flex flex-row gap-5 max-md:flex-col">
    <!-- Motto card (gray-blue) -->
    <div class="scroll-reveal-item flex-1 rounded-lg p-[3rem_2.44rem] bg-section-gray-blue flex flex-col gap-10" style="--sr-delay: 0ms">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" width="52" height="52" fill="currentColor" aria-hidden="true">
        <path d="M32 0H48h80 16V16 144h64 16v16 16h48V80 64h16 80 16V80 224v16V352c0 88.4-71.6 160-160 160H160C71.6 512 0 440.4 0 352V256 240H16 32V16 0zM224 208l0 32v16l0 16 0 48h48V240 208H224zm-32 64l0 0H144v0H112v0H32v80c0 70.7 57.3 128 128 128h64c70.7 0 128-57.3 128-128V240 224 96H304v80 16 48 96 16H288 224 208 192 112 96V320h16 80l0-48zm-80-32V160 144 32H64V240h48zm32 0h48V192 176H144v64z"/>
      </svg>
      <h2 class="m-0 text-6xl font-normal leading-hero text-black max-md:text-hero-secondary max-md:leading-hero-sm">All we care is the<br />Code and UX</h2>
    </div>

    <!-- Why Oursky card (blue) -->
    <div class="scroll-reveal-item flex-1 rounded-lg p-[3rem_2.44rem] bg-section-blue-dark flex flex-col gap-10" style="--sr-delay: 80ms">
      <div>
        <h2 class="text-white whitespace-nowrap m-0 text-[18px] font-black leading-[24px]">WHY OURSKY?</h2>
        <p class="text-white mt-10 m-0 text-lg font-normal leading-[24px]">
          Since 2009, we have been providing quality custom software development for a variety of platforms and industries.
          <br /><br />
          Our global team of 70 makers, create apps, design and custom software for our clients, from Apple App of the Years startups to NASDAQ listed companies.
          <br /><br />
          We have a dynamic, open, and respectful culture that encourages people to bring their whole self to their work.
          <br /><br />
          What's your next big idea?
        </p>
      </div>
    </div>
  </div>

  <!-- Statistics grid -->
  <div class="statistics-container scroll-reveal-group grid grid-cols-3 gap-y-[3.75rem] mt-5 p-10 max-md:grid-cols-2 max-md:p-4" aria-label="Company statistics">
    {stats.map((stat) => (
      <div class="statistics scroll-reveal-item flex flex-col items-center gap-2">
        <div class="flex justify-center items-center" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" height="48" width="48" viewBox={stat.viewBox}>
            <path fill={stat.color} d={stat.icon} />
          </svg>
        </div>
        <p class="statistics__number m-0 text-[2.625rem] font-medium leading-[3.75rem] text-center" data-count={stat.count}>{stat.number}</p>
        <p class="m-0 text-lg font-normal leading-6 text-center">
          {stat.title}
          {stat.subtitle && <><br /><span class="text-sm">{stat.subtitle}</span></>}
        </p>
      </div>
    ))}
  </div>
</section>
