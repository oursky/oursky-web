---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import IntroSection from '../components/home/IntroSection.astro';
import WorksPreviewSection from '../components/home/WorksPreviewSection.astro';
import ProductsSection from '../components/home/ProductsSection.astro';
import ClientLogosSection from '../components/home/ClientLogosSection.astro';
import TestimonialsSection from '../components/home/TestimonialsSection.astro';
import BlogPreviewSection from '../components/home/BlogPreviewSection.astro';
import ActionCardsSection from '../components/home/ActionCardsSection.astro';
import ContactCtaSection from '../components/home/ContactCtaSection.astro';
---

<BaseLayout
  title="Build it right the First Time"
  description="We are a developer-led software agency comprising a diverse team of experts who work with startups and enterprises to create award-winning digital experiences and fast-track digital transformation."
  bodyClass="page--home"
>
  <!--
    Single horizontal rail: same max-width + gutters as Webflow .content-container (1360 / 2.5rem).
    Rail tokens live on :root (global.css); sections align with the hero video card edges.
  -->
  <div class="home-page min-w-0 overflow-x-clip">
    <!--
      Wraps hero + intro: light gray background, max-width 1360px, centered.
      The hero card (border-radius 48px) fills the rail content box.
    -->
    <div class="bg-bg-hero flex flex-col items-stretch w-full max-w-[var(--home-rail-max)] mx-auto pt-4 px-[var(--home-rail-gutter)] gap-0 overflow-visible box-border lg:pt-10 max-md:max-w-none max-md:p-0">
      <HeroSection />
      <IntroSection />
    </div>

    <!-- Full-width section backgrounds; inner rails use --home-rail-* -->
    <WorksPreviewSection />
    <ProductsSection />
    <ClientLogosSection />
    <TestimonialsSection />

    <!--
      Last section: light gray (#f7f7f7) rounded-top section containing
      the blog scroll, action cards, and contact form.
    -->
    <section class="bg-bg-section-light rounded-t-[40px] flex flex-col justify-center items-center w-full overflow-hidden p-0">
      <div class="w-full max-w-[var(--home-rail-max)] mx-auto box-border">
        <BlogPreviewSection />
      </div>

      <div class="w-full max-w-[var(--home-rail-max)] mx-auto px-[var(--home-rail-gutter)] pb-8 bg-bg-section-light rounded-t-[40px] flex flex-col gap-8 box-border max-md:pb-6 max-md:gap-6">
        <ActionCardsSection />
        <ContactCtaSection />
      </div>
    </section>
  </div>

  <script>
    function initHomeScrollReveal() {
      const singles = document.querySelectorAll('.home-page .scroll-reveal');
      const groups = document.querySelectorAll('.home-page .scroll-reveal-group');
      if (!singles.length && !groups.length) return;

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) {
        singles.forEach((el) => el.classList.add('scroll-reveal--visible'));
        groups.forEach((el) => el.classList.add('scroll-reveal-group--visible'));
        return;
      }

      const io = new IntersectionObserver(
        (entries, observer) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const t = entry.target;
            if (t.classList.contains('scroll-reveal-group')) {
              t.classList.add('scroll-reveal-group--visible');
            } else {
              t.classList.add('scroll-reveal--visible');
            }
            observer.unobserve(t);
          }
        },
        { root: null, rootMargin: '0px 0px -5% 0px', threshold: 0.05 }
      );

      singles.forEach((el) => io.observe(el));
      groups.forEach((el) => io.observe(el));
    }

    document.addEventListener('astro:page-load', initHomeScrollReveal);
  </script>
</BaseLayout>
