---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const works = await getCollection('works', ({ data }) => !data.draft);
works.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Works"
  description="A selection of our product work — mobile apps, web platforms, and digital experiences built for clients worldwide."
>
  <main class="max-w-[var(--max-w-content)] mx-auto px-[var(--spacing-page-x)] lg:px-[var(--spacing-page-x-lg)] py-16">
    <header class="mb-12">
      <h1 class="text-4xl lg:text-5xl font-bold mb-4">Our Work</h1>
      <p class="text-xl text-[var(--color-brand-gray-700)] max-w-2xl">
        We partner with ambitious teams to build products that stand the test of time.
      </p>
    </header>

    {
      works.length === 0 ? (
        <p class="text-[var(--color-brand-gray-500)]">
          Case studies are being imported — check back soon.
        </p>
      ) : (
        <ul class="grid gap-10 lg:grid-cols-2">
          {works.map((work) => {
            const img = work.data.thumbnail ?? work.data.heroImage;
            return (
              <li>
                <a href={`/works/${work.id}`} class="group block">
                  {img && (
                    <div class="overflow-hidden rounded-xl mb-5 aspect-video bg-[var(--color-brand-gray-100)]">
                      <img
                        src={img}
                        alt={work.data.heroImageAlt ?? work.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-primary)] mb-2">
                    {work.data.industry}
                  </p>
                  <h2 class="text-2xl font-bold leading-snug group-hover:text-[var(--color-brand-primary)] transition-colors">
                    {work.data.title}
                  </h2>
                  <p class="text-[var(--color-brand-gray-700)] mt-2 leading-relaxed">
                    {work.data.description}
                  </p>
                </a>
              </li>
            );
          })}
        </ul>
      )
    }
  </main>
</BaseLayout>
