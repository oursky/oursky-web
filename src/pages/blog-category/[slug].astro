---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const categories = await getCollection('categories');
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);

  return categories.map((cat) => {
    const posts = allPosts
      .filter((p) => p.data.categories.includes(cat.data.slug))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return {
      params: { slug: cat.data.slug },
      props: { category: cat, posts },
    };
  });
}

const { category, posts } = Astro.props;
const { name, description } = category.data;
---

<BaseLayout
  title={`${name} — Blog`}
  description={description ?? `All blog posts in the ${name} category.`}
>
  <main class="max-w-[var(--home-rail-max)] mx-auto pt-page-top px-[var(--home-rail-gutter)] pb-16 max-lg:pt-page-top-tablet box-border">
    <header class="mb-12">
      <div class="ml-5 max-sm:ml-0">
        <h1 class="blog-page-title inline-block m-0 mb-4 text-5xl font-semibold leading-hero pb-2 max-md:text-hero-secondary max-md:leading-hero-sm">View Posts By Category</h1>
      </div>
      <p class="ml-5 max-sm:ml-0 text-2xl font-medium leading-desc text-black m-0 max-md:text-lg max-md:leading-desc-sm">{name}</p>
    </header>

    {
      posts.length === 0 ? (
        <p class="text-text-muted">No posts in this category yet.</p>
      ) : (
        <ul class="grid gap-6 sm:grid-cols-2 list-none p-0 m-0">
          {posts.map((post) => (
            <li class="bg-surface border border-[#E0E9EC] rounded-[20px] overflow-hidden transition-shadow hover:shadow-[0_2px_5px_rgba(0,0,0,0.1)]">
              <a href={`/blogs/${post.id}`} class="group block no-underline text-text p-10 pb-5">
                <h3 class="text-base font-medium text-black uppercase tracking-[0.02em] leading-footer truncate m-0">
                  {name}
                </h3>
                {post.data.image && (
                  <div class="w-full h-[17.5rem] overflow-hidden rounded-md bg-muted mt-4 max-md:h-44">
                    <img
                      src={post.data.image}
                      alt={post.data.imageAlt ?? post.data.title}
                      class="w-full h-full object-cover block transition-transform duration-300 group-hover:scale-[1.04]"
                      loading="lazy"
                    />
                  </div>
                )}
                <h2 class="text-[2rem] font-normal text-black leading-footer m-0 mt-4 line-clamp-3 group-hover:text-primary">
                  {post.data.title}
                </h2>
                <p class="text-text-muted text-sm mt-3 m-0">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )
    }

    <div class="mt-12">
      <a href="/blog" class="text-primary hover:underline font-medium">
        &larr; All Posts
      </a>
    </div>
  </main>
</BaseLayout>

<style>
  .blog-page-title {
    background-image: var(--gradient-page-title);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
