---
/**
 * ActionCardsSection — Newsletter signup + social media follow cards.
 *
 * Webflow: ActionCardsContainer component (componentId: 4f905d05-a3db-b075-6fd3-6641fb2041b5)
 * Located in: .action-section div inside .section__home__lastsection
 *
 * Visual: Two side-by-side rounded cards:
 *   Left (blue #1a4fff): email input + Subscribe button
 *   Right (dark #2c2c2c): social icon row
 */

const socialLinks = [
  { href: 'https://www.facebook.com/oursky.hk', label: 'Facebook', icon: 'facebook' },
  { href: 'https://www.linkedin.com/company/oursky/', label: 'LinkedIn', icon: 'linkedin' },
  { href: 'https://www.instagram.com/oursky.hk/', label: 'Instagram', icon: 'instagram' },
  { href: 'https://x.com/ourskylab', label: 'X (Twitter)', icon: 'x' },
  { href: 'https://mastodon.social/@oursky', label: 'Mastodon', icon: 'mastodon' },
  { href: 'https://github.com/oursky', label: 'GitHub', icon: 'github' },
];
---

<div class="scroll-reveal-group grid grid-cols-2 max-md:grid-cols-1 gap-5 pt-10 w-full">
  <!-- Left card: Newsletter -->
  <div class="rounded-lg p-8 flex flex-col gap-6 bg-[#1a4fff]">
    <p class="scroll-reveal-item text-xl font-bold text-white leading-tight m-0" style="--sr-delay: 0ms">Get updates and tips from the team</p>
    <form class="scroll-reveal-item flex gap-3 flex-wrap" style="--sr-delay: 55ms" action="#" method="post" onsubmit="return false">
      <label for="newsletter-email" class="sr-only">Your Email</label>
      <input
        id="newsletter-email"
        type="email"
        name="email"
        class="flex-1 min-w-40 px-5 py-3 rounded-full bg-white/20 text-white text-sm border-0 outline-none placeholder:text-white/65 focus:bg-white/30 transition-colors"
        placeholder="Your Email"
        autocomplete="email"
        required
      />
      <button
        type="submit"
        class="flex-none px-6 py-3 rounded-full border-2 border-white/70 bg-transparent text-white text-sm font-semibold cursor-pointer hover:bg-white hover:text-[#1a4fff] hover:border-white transition-all"
      >
        Subscribe
      </button>
    </form>
  </div>

  <!-- Right card: Follow Us -->
  <div class="rounded-lg p-8 flex flex-col gap-6 bg-[#2c2c2c]">
    <p class="scroll-reveal-item text-xl font-bold text-white m-0" style="--sr-delay: 110ms">Follow Us</p>
    <div class="scroll-reveal-item flex gap-5 items-center flex-wrap" style="--sr-delay: 175ms" aria-label="Social media links">
      {socialLinks.map((s) => (
        <a
          href={s.href}
          class="flex items-center justify-center w-7 h-7 text-white no-underline transition-all hover:opacity-75 hover:scale-110 [&_svg]:w-full [&_svg]:h-full [&_svg]:fill-current"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.label}
        >
          {s.icon === 'facebook' && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          )}
          {s.icon === 'linkedin' && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          )}
          {s.icon === 'instagram' && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          )}
          {s.icon === 'x' && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          )}
          {s.icon === 'mastodon' && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 00.023-.043v-1.809a.052.052 0 00-.02-.041.053.053 0 00-.046-.01 20.282 20.282 0 01-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 01-.319-1.433.053.053 0 01.066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z"/></svg>
          )}
          {s.icon === 'github' && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          )}
        </a>
      ))}
    </div>
  </div>
</div>
