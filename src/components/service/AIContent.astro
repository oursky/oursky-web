---

<div class="flex flex-col gap-[3.75rem]">
  <!-- Dark-blue intro card -->
  <section class="scroll-reveal-group w-full" aria-label="About our AI services">
    <div class="bg-[#282d49] rounded-lg px-8 pt-[2.8rem] pb-14 max-md:px-5 max-md:pt-8 max-md:pb-10 flex flex-row gap-16 items-center max-lg:flex-col max-lg:gap-8 max-md:gap-6 scroll-reveal-item" style="--sr-delay: 0ms">
      <div class="w-[28%] shrink-0 flex justify-center max-lg:w-32 max-sm:w-24">
        <img
          src="/images/Icon-iOS-Default-1024x10242x.webp"
          alt="Oursky AI"
          class="w-full object-contain max-lg:w-32 max-sm:w-24"
          loading="lazy"
        />
      </div>
      <div class="flex-1 scroll-reveal-item" style="--sr-delay: 80ms">
        <p class="m-0 text-white text-lg leading-8">
          Oursky has refined AI capabilities for over a decade, delivering solutions like{' '}
          <a href="https://formx.ai/" target="_blank" rel="noopener noreferrer" class="text-yellow-300 underline">FormX</a>{' '}
          for document automation and integrating{' '}
          <a href="https://skytest.ai/" target="_blank" rel="noopener noreferrer" class="text-yellow-300 underline">Skytest.ai</a>{' '}
          into delivery pipelines to address real business challenges.
        </p>
        <p class="mt-4 mb-0 text-white text-lg leading-8 font-bold">AI Accelerates—But Expertise Unlocks the Value</p>
        <p class="mt-2 mb-0 text-white text-lg leading-8">
          Our distinction lies in combining AI with human expertise. Our professionals understand that effective AI
          use goes beyond automation—it requires strategic questioning, precise tool selection, and rigorous quality
          assurance. AI accelerates software delivery, but our engineers, designers, and QA specialists ensure its
          value through their insight and judgment. Their expertise guarantees robust, secure, and production-ready
          solutions, making AI a powerful tool guided by human intelligence.
        </p>
      </div>
    </div>
  </section>

  <!-- AI approach items -->
  <section class="scroll-reveal-group w-full" aria-label="How our experts work with AI">
    <div class="flex flex-col gap-6 max-md:gap-5 scroll-reveal-item" style="--sr-delay: 0ms">
      <h2 class="m-0 text-2xl font-black text-black leading-[2.25rem]">How our experts work with AI</h2>
      <div class="flex flex-wrap gap-8 max-md:gap-10 max-sm:gap-10 max-sm:flex-col">
        {approachItems.map((item) => (
          <div class="flex-1 min-w-[200px] max-sm:min-w-0 flex flex-col gap-3">
            <div class="text-black" set:html={item.icon} />
            <h3 class="m-0 text-lg font-bold text-black leading-6">{item.title}</h3>
            <p class="m-0 text-base leading-[1.2rem] text-black">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Statistics -->
  <ServiceStatisticsSection stats={stats} />

  <!-- AI Products -->
  <section class="scroll-reveal-group w-full" aria-label="Our AI products">
    <div class="flex flex-col gap-8 scroll-reveal-item" style="--sr-delay: 0ms">
      <h2 class="m-0 text-2xl font-black text-black text-center leading-[2.25rem]">Our Products leveraging the Power of AI</h2>
      <div class="flex flex-row gap-8 justify-center max-sm:flex-col max-sm:items-center scroll-reveal-item" style="--sr-delay: 80ms">
        <a href="https://formx.ai/" target="_blank" rel="noopener noreferrer" class="flex-1 max-w-[300px] flex flex-col items-center gap-3 mt-12 no-underline text-black hover:opacity-80 transition-opacity">
          <img src="/images/fx-icon.webp" alt="FormX" class="w-[260px] object-contain" loading="lazy" />
          <h3 class="m-0 text-[2rem] font-semibold leading-[2.625rem]">FormX</h3>
          <p class="m-0 text-lg text-center leading-8">Automate Data Processing with AI</p>
        </a>
        <a href="https://skytest.ai/" target="_blank" rel="noopener noreferrer" class="flex-1 max-w-[300px] flex flex-col items-center gap-3 mt-12 no-underline text-black hover:opacity-80 transition-opacity">
          <img src="/images/skytest-icon.webp" alt="Skytest.ai" class="w-[260px] object-contain" loading="lazy" />
          <h3 class="m-0 text-[2rem] font-semibold leading-[2.625rem]">Skytest.ai</h3>
          <p class="m-0 text-lg text-center leading-8">Enterprise-Grade E2E Testing<br />at a Fraction of the Cost</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Dark circles section -->
  <ServiceCirclesSection />

  <!-- Shared "why Oursky" methodologies -->
  <ServiceSharedMethodologies />
</div>
