---
/**
 * RelatedBlogSection — "Read more" horizontal-scroll strip on blog detail pages.
 *
 * Webflow: .blog-section.blogpage under the "Read more" section badge on detail_blogs.
 * Selection: 6 most recent posts, excluding the current one.
 */
import { getCollection } from 'astro:content';
import SectionBadge from '../ui/SectionBadge.astro';
import BlogCard from './BlogCard.astro';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const [allPosts, allCategories] = await Promise.all([
  getCollection('blog', ({ data }) => !data.draft),
  getCollection('categories'),
]);

const categoryNameBySlug = new Map(allCategories.map((c) => [c.data.slug, c.data.name]));

const prettySlug = (slug: string) =>
  slug ? slug.split('-').map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') : '';
const categoryLabel = (slug: string) => categoryNameBySlug.get(slug) ?? prettySlug(slug);

const MAX = 6;
const relatedPosts = allPosts
  .filter((p) => p.id !== currentSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, MAX);
---

<div class="w-full">
  <div
    class="flex items-center justify-between px-10 pt-10 pb-4 w-full max-md:px-5 max-md:pt-8 max-md:pb-3"
    style="--sr-delay: 0ms"
  >
    <SectionBadge label="Read more" />
    <SectionBadge label="View All ➞" href="/blog/" variant="viewall" />
  </div>

  <section class="related-blog-section relative pb-10 max-md:pb-8" aria-label="Related posts">
    <div class="related-blog-scroll-wrapper">
      {relatedPosts.length === 0 ? (
        <p class="p-8 text-text-muted" style="--sr-delay: 40ms">No other posts yet.</p>
      ) : (
        <ul
          class="related-blog-card-list flex gap-6 overflow-x-auto overflow-y-visible snap-x [scrollbar-width:none] list-none py-2 pb-4 m-0"
          role="list"
        >
          {relatedPosts.map((post, i) => {
            const firstCat = post.data.categories[0];
            const topLabel = post.data.displayCategory ?? categoryLabel(firstCat);
            const pillSlugs = post.data.tags.length > 0 ? post.data.tags : post.data.categories;
            const pills = pillSlugs.map((slug) => ({ slug, label: categoryLabel(slug) }));
            return (
              <li
                class="snap-start shrink-0 grow-0 basis-[34.5rem] w-[34.5rem] min-w-[34.5rem] flex max-lg:basis-[26rem] max-lg:w-[26rem] max-lg:min-w-[26rem] max-md:w-72 max-md:min-w-72 max-md:basis-72"
                style={`--sr-delay: ${45 + i * 48}ms`}
              >
                <BlogCard post={post} topLabel={topLabel} pills={pills} />
              </li>
            );
          })}
        </ul>
      )}
    </div>

    <button
      class="related-blog-btn related-blog-btn--left absolute top-1/2 -translate-y-1/2 left-6 w-12 h-12 rounded-full border-0 cursor-pointer flex items-center justify-center text-white bg-black/30 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity z-10 max-md:hidden"
      aria-label="Scroll left"
      type="button"
    >
      <span class="flex items-center justify-center" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" class="h-4 w-auto" aria-hidden="true">
          <path fill="currentColor" d="M34.5 239L228.9 44.7c9.4-9.4 24.6-9.4 33.9 0l22.7 22.7c9.4 9.4 9.4 24.5 0 33.9L131.5 256l154 154.8c9.3 9.4 9.3 24.5 0 33.9l-22.7 22.7c-9.4 9.4-24.6 9.4-33.9 0L34.5 273c-9.4-9.4-9.4-24.6 0-33.9z"/>
        </svg>
      </span>
    </button>
    <button
      class="related-blog-btn related-blog-btn--right absolute top-1/2 -translate-y-1/2 right-6 w-12 h-12 rounded-full border-0 cursor-pointer flex items-center justify-center text-white bg-black/30 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity z-10 max-md:hidden"
      aria-label="Scroll right"
      type="button"
    >
      <span class="flex items-center justify-center" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" class="h-4 w-auto" aria-hidden="true">
          <path fill="currentColor" d="M285.5 273L91.1 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.7-22.7c-9.4-9.4-9.4-24.5 0-33.9L188.5 256 34.5 101.3c-9.3-9.4-9.3-24.5 0-33.9l22.7-22.7c9.4-9.4 24.6-9.4 33.9 0L285.5 239c9.4 9.4 9.4 24.6 0 33.9z"/>
        </svg>
      </span>
    </button>
  </section>
</div>

<style>
  .related-blog-scroll-wrapper {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
  }

  .related-blog-card-list {
    padding-left: max(calc((100vw - var(--home-rail-max)) / 2 + var(--home-rail-gutter)), var(--home-rail-gutter));
    padding-right: max(calc((100vw - var(--home-rail-max)) / 2 + var(--home-rail-gutter)), var(--home-rail-gutter));
    scroll-padding-left: max(calc((100vw - var(--home-rail-max)) / 2 + var(--home-rail-gutter)), var(--home-rail-gutter));
  }

  .related-blog-card-list::-webkit-scrollbar {
    display: none;
  }

  .related-blog-section:hover .related-blog-btn {
    opacity: 1;
    pointer-events: auto;
  }

  .related-blog-section:hover .related-blog-btn:hover {
    opacity: 0.65;
  }

  .related-blog-btn:focus-visible {
    opacity: 1;
    pointer-events: auto;
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }
</style>

<script>
  const leftBtn = document.querySelector('.related-blog-btn--left');
  const rightBtn = document.querySelector('.related-blog-btn--right');
  const list = document.querySelector('.related-blog-card-list') as HTMLElement | null;

  const SCROLL_AMOUNT = 580;

  leftBtn?.addEventListener('click', () => {
    list?.scrollBy({ left: -SCROLL_AMOUNT, behavior: 'smooth' });
  });

  rightBtn?.addEventListener('click', () => {
    list?.scrollBy({ left: SCROLL_AMOUNT, behavior: 'smooth' });
  });
</script>
