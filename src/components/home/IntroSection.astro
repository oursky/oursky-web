---
import PillButton from '../ui/PillButton.astro';
---

<section
  class="intro-section-home scroll-reveal-group flex w-full flex-col items-start gap-10 bg-bg text-xl-plus leading-10 box-border mt-section mb-[100px] max-md:mt-8 max-md:mb-12 max-md:px-[var(--home-rail-gutter)] max-md:text-lg max-md:leading-7 lg:flex-row lg:flex-wrap lg:items-center lg:justify-between"
  aria-label="Introduction"
>
  <img
    src="/images/os-w-1-2.svg"
    loading="lazy"
    alt=""
    aria-hidden="true"
    class="scroll-reveal-item max-w-[320px] shrink-0 max-lg:max-w-[200px] max-md:max-w-[140px]"
    style="--sr-delay: 0ms"
  />
  <p class="scroll-reveal-item mb-0 w-full lg:flex-1" style="--sr-delay: 75ms">
    <span class="font-semibold">Welcome to Oursky</span>
    <span class="inline max-md:hidden">&nbsp;⎯⎯⎯⎯⎯&nbsp;</span>
    <span class="hidden max-md:inline">&nbsp;⎯⎯⎯&nbsp;</span>Across Hong Kong, London, Taipei, Tokyo, and Canada, our talented and
    close-knit team of developers, designers, and product managers is driven
    to help you craft the unique experience with excellent user experiences
    and cutting-edge technologies.
  </p>
  <span class="scroll-reveal-item self-start shrink-0" style="--sr-delay: 150ms">
    <PillButton href="/about" label="Meet The Team" variant="secondary" />
  </span>
</section>
