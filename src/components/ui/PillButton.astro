---
/**
 * PillButton — Oursky pill-shaped button / link.
 *
 * Three style variants:
 *   primary  — amber fill (#ffbb55), black text
 *   secondary — outline (border + transparent bg)
 *   ghost    — no border, text only; optional dark pill variant via onDark
 *
 * Renders as <a> when `href` is supplied, <button> otherwise.
 * Pass `onDark` when the button sits on a dark background.
 */

interface Props {
  href?: string;
  label: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'default' | 'sm';
  onDark?: boolean;
  external?: boolean;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  style?: string;
  /** Force a full page reload instead of view-transition swap (use for pages with reCAPTCHA). */
  reload?: boolean;
}

const {
  href,
  label,
  variant = 'secondary',
  size = 'default',
  onDark = false,
  external = false,
  type = 'button',
  class: extraClass,
  style,
  reload = false,
} = Astro.props;

const isGhost = variant === 'ghost';
const isSmall = size === 'sm';

// Height + padding only for non-ghost (ghost controls its own sizing)
const sizeClass = isGhost ? '' : isSmall
  ? 'h-12 px-8 text-base'
  : 'h-[4.25rem] px-[3.125rem] text-lg';

// Variant × theme class strings — listed verbatim so Tailwind detects each class
const variantMap: Record<string, Record<string, string>> = {
  primary: {
    light: 'font-black bg-primary-dark text-black hover:scale-105 hover:shadow-[0_4px_16px_rgba(226,159,52,0.4)]',
    dark:  'font-black bg-primary-dark text-black hover:scale-105 shadow-[0_0_0_2px_rgba(255,187,85,0.3)]',
  },
  secondary: {
    light: 'font-medium border-[1.5px] border-black text-black bg-transparent hover:bg-black hover:text-white',
    dark:  'font-medium border-[1.5px] border-white/85 text-white bg-transparent hover:bg-white/15',
  },
  ghost: {
    light: 'font-medium text-text h-auto px-0 py-2 text-base hover:opacity-60',
    dark:  'font-medium bg-white/18 border border-white/25 text-white h-auto px-6 py-3 text-base hover:bg-white/30',
  },
};

const theme = onDark ? 'dark' : 'light';
const vClasses = variantMap[variant]?.[theme] ?? '';

const classes = [
  'inline-flex items-center justify-center whitespace-nowrap no-underline cursor-pointer rounded-full transition-all duration-300',
  sizeClass,
  vClasses,
  extraClass,
].filter(Boolean).join(' ');

const externalAttrs = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

{href ? (
  <a href={href} class={classes} style={style} {...externalAttrs} data-astro-reload={reload ? '' : undefined}>{label}</a>
) : (
  <button type={type} class={classes} style={style}>{label}</button>
)}
