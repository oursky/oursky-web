---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostList from '../../components/blog/BlogPostList.astro';
import BlogPagination from '../../components/blog/BlogPagination.astro';
import { BLOG_POSTS_PER_PAGE, getSortedPublishedPosts } from '../../data/blog-paging';

export async function getStaticPaths() {
  const allPosts = await getSortedPublishedPosts();
  const totalPages = Math.max(1, Math.ceil(allPosts.length / BLOG_POSTS_PER_PAGE));
  if (totalPages <= 1) {
    return [];
  }
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const pageParam = Astro.params.page;
const currentPage = Math.max(2, parseInt(String(pageParam), 10) || 2);
const allPosts = await getSortedPublishedPosts();
const totalPages = Math.max(1, Math.ceil(allPosts.length / BLOG_POSTS_PER_PAGE));
const start = (currentPage - 1) * BLOG_POSTS_PER_PAGE;
const pagePosts = allPosts.slice(start, start + BLOG_POSTS_PER_PAGE);
---

<BaseLayout
  title="Blog"
  description="Thoughts on software engineering, product design, and building remarkable digital products from the Oursky team."
>
  <main class="max-w-[var(--home-rail-max)] mx-auto pt-page-top px-[var(--home-rail-gutter)] pb-16 max-lg:pt-page-top-tablet box-border">
    <header class="mb-12">
      <div class="ml-5 max-sm:ml-0">
        <h1 class="blog-page-title inline-block m-0 mb-4 text-5xl font-semibold leading-hero pb-2 max-md:text-hero-secondary max-md:leading-hero-sm">Blog</h1>
      </div>
      <p class="ml-5 max-sm:ml-0 text-xl text-black m-0">
        Our latest news and insights
        {totalPages > 1 && <span class="text-text-muted"> (page {currentPage} of {totalPages})</span>}
      </p>
    </header>

    <BlogPostList posts={pagePosts} />
    <BlogPagination currentPage={currentPage} totalPages={totalPages} />
  </main>
</BaseLayout>

<style>
  .blog-page-title {
    background-image: var(--gradient-page-title);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
