---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostList from '../../components/blog/BlogPostList.astro';
import BlogPagination from '../../components/blog/BlogPagination.astro';
import { BLOG_POSTS_PER_PAGE, getSortedPublishedPosts } from '../../data/blog-paging';

const allPosts = await getSortedPublishedPosts();
const totalPages = Math.max(1, Math.ceil(allPosts.length / BLOG_POSTS_PER_PAGE));
const pagePosts = allPosts.slice(0, BLOG_POSTS_PER_PAGE);
---

<BaseLayout
  title="Blog"
  description="Thoughts on software engineering, product design, and building remarkable digital products from the Oursky team."
>
  <main class="blog-page max-w-[var(--home-rail-max)] mx-auto pt-page-top px-[var(--home-rail-gutter)] pb-16 max-lg:pt-page-top-tablet box-border">
    <header class="scroll-reveal-group mb-12">
      <div class="ml-5 max-sm:ml-0 scroll-reveal-item" style="--sr-delay: 0ms">
        <h1 class="blog-page-title inline-block m-0 mb-4 text-5xl font-semibold leading-hero pb-2 max-md:text-hero-secondary max-md:leading-hero-sm">Blog</h1>
      </div>
      <p class="ml-5 max-sm:ml-0 text-xl text-black m-0 scroll-reveal-item" style="--sr-delay: 80ms">
        Our latest news and insights
      </p>
    </header>

    {allPosts.length === 0 && <p class="text-text-muted">Posts are being imported — check back soon.</p>}
    {allPosts.length > 0 && <BlogPostList posts={pagePosts} />}
    {allPosts.length > 0 && <BlogPagination currentPage={1} totalPages={totalPages} />}
  </main>
</BaseLayout>

<style>
  .blog-page-title {
    background-image: var(--gradient-page-title);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>

<script>
  function initPage() {
    const root = document.querySelector('.blog-page');
    if (!root) return;
    const singles = root.querySelectorAll('.scroll-reveal');
    const groups = root.querySelectorAll('.scroll-reveal-group');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      singles.forEach((el) => el.classList.add('scroll-reveal--visible'));
      groups.forEach((el) => el.classList.add('scroll-reveal-group--visible'));
    } else if (singles.length || groups.length) {
      const io = new IntersectionObserver(
        (entries, observer) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const t = entry.target;
            t.classList.add(t.classList.contains('scroll-reveal-group') ? 'scroll-reveal-group--visible' : 'scroll-reveal--visible');
            observer.unobserve(t);
          }
        },
        { root: null, rootMargin: '0px 0px -5% 0px', threshold: 0.05 }
      );
      singles.forEach((el) => io.observe(el));
      groups.forEach((el) => io.observe(el));
    }
  }

  initPage();
  document.addEventListener('astro:page-load', initPage);
</script>
