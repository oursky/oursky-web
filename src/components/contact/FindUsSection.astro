---
/**
 * FindUsSection — Office location details.
 *
 * Webflow ref: .find-us-section / .find-us
 * Desktop: flex row — 1/3 title column + 2/3 address details.
 * Mobile: flex column; address pairs also stack vertically.
 */
---

<section class="w-full scroll-reveal-group" aria-label="Find us">
  <div class="flex flex-row gap-5 max-md:flex-col max-md:gap-12">
    <div class="basis-1/3 max-w-[27.313rem] shrink-0">
      <h2 class="scroll-reveal-item text-2xl font-black leading-9 m-0" style="--sr-delay: 0ms">Find us</h2>
    </div>

    <div class="flex-1 flex flex-col gap-[3.94rem] max-md:gap-12">
      <!-- Oursky offices -->
      <div class="flex flex-col scroll-reveal-item" style="--sr-delay: 60ms">
        <h2 class="text-2xl font-black leading-9 m-0">Oursky</h2>
        <div class="flex flex-row gap-5 mt-[3.94rem] max-md:flex-col max-md:gap-12 max-md:mt-12">
          <div class="flex-1">
            <h3 class="text-2xl font-medium leading-9 mt-0 mb-0">Hong Kong</h3>
            <p class="text-lg font-normal leading-10 text-black mt-5 mb-0">
              <a
                href="https://goo.gl/maps/mV8zNAqgUNt"
                target="_blank"
                rel="noopener noreferrer"
                class="text-newsletter-blue underline"
              >
                Rm B, 10/F, Great Wall Factory Bldg, 11 Cheung Shun St, Cheung Sha Wan, Hong Kong (Lai Chi Kok MTR Exit D2)
              </a><br />
              +852 2155 9299 (Office)<br />
              +852 3020 0215 (Fax)
            </p>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-medium leading-9 mt-0 mb-0">Taipei</h3>
            <p class="text-lg font-normal leading-10 text-black mt-5 mb-0">
              <a
                href="https://maps.app.goo.gl/u4wCsGMiP7RrbqFR9"
                target="_blank"
                rel="noopener noreferrer"
                class="text-newsletter-blue underline"
              >
                6F.-2, No. 666, Sec. 4, Bade Rd., Songshan Dist., Taipei City 105057, Taiwan
              </a><br /><br />
              +886 2 2712 0059 (Office)
            </p>
          </div>
        </div>
      </div>

      <!-- SkyMakers offices -->
      <div class="flex flex-col scroll-reveal-item" style="--sr-delay: 120ms">
        <h3 class="text-2xl font-black leading-9 m-0">SkyMakers (Strategic Partner)</h3>
        <div class="flex flex-row gap-5 mt-[3.94rem] max-md:flex-col max-md:gap-12 max-md:mt-12">
          <div class="flex-1">
            <h3 class="text-2xl font-medium leading-9 mt-0 mb-0">Greater Manchester</h3>
            <p class="text-lg font-normal leading-10 text-black mt-5 mb-0">
              SkyMakers Digital Limited,<br />
              Bank Chambers, St. Petersgate, Stockport, SK1 1AR, United Kingdom<br /><br />
              +44 16 1818 8339 (Office)
            </p>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-medium leading-9 mt-0 mb-0">Tokyo</h3>
            <p class="text-lg font-normal leading-10 text-black mt-5 mb-0">
              東京都渋谷区神宮前六丁目23番4号桑野ビル2階<br />
              SkyMakers LLC スカイクリエーター合同会社
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
