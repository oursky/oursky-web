---
import BaseLayout from '../layouts/BaseLayout.astro';
import PillButton from '../components/ui/PillButton.astro';
---

<BaseLayout title="Not Found — Oursky" description="Page not found">
  <div class="flex flex-col items-center justify-center min-h-[70vh] text-center px-5 py-16">
    <div class="flex flex-col items-center w-[260px]">
      <div class="w-[180px] aspect-square rounded-full overflow-hidden mb-6 shrink-0">
        <img
          src="/images/404.jpg"
          alt=""
          class="w-full h-full object-cover block"
          loading="eager"
        />
      </div>
      <h1 class="text-2xl font-bold text-black m-0 mb-3">Oops...</h1>
      <p class="text-text m-0 mb-6 text-base leading-snug">
        The page you are looking for doesn't exist or has been moved
      </p>
      <PillButton href="/" label="Back to home" variant="secondary" />
    </div>
  </div>
</BaseLayout>
