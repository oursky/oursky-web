<section class="w-full scroll-reveal-group" aria-label="Development services">
  <div class="bg-section-blue rounded-lg px-8 pt-[2.8rem] pb-14 flex flex-col gap-8 max-md:px-5 max-md:pt-8 max-md:pb-10">
    <div class="flex items-center gap-5 scroll-reveal-item max-sm:flex-col max-sm:items-start max-sm:gap-4" style="--sr-delay: 0ms">
      <div class="w-[15%] self-start shrink-0 max-lg:flex-none max-sm:w-[80px]">
        <img src="/images/development-service.webp" alt="Software development" class="w-full h-full object-contain" loading="lazy" />
      </div>
      <h2 class="m-0 text-white text-3xl font-semibold leading-section max-lg:text-2xl max-lg:leading-desc">Development</h2>
    </div>
    <div class="flex flex-wrap gap-16 max-lg:gap-10 max-sm:flex-col max-sm:gap-10 scroll-reveal-item" style="--sr-delay: 80ms">
      {services.map((svc) => (
        <div class="flex-1 min-w-64 max-sm:min-w-0 flex flex-col gap-3">
          <div class="service-icon text-white" set:html={svc.icon} />
          <h3 class="m-0 text-white text-lg font-semibold leading-6">{svc.title}</h3>
          <p class="m-0 text-white text-lg leading-6 font-normal">
            {svc.description.split('\n\n').map((para, i) => (
              <span class="para-block">{para}{i < svc.description.split('\n\n').length - 1 && <><br /><br /></>}</span>
            ))}
          </p>
          {svc.link && (
            <a href={svc.link} class="text-link-on-dark text-base underline decoration-1 mt-2">{svc.linkLabel}</a>
          )}
        </div>
      ))}
    </div>
  </div>

  <div class="flex flex-row gap-8 max-sm:gap-10 mt-12 max-lg:flex-wrap max-sm:flex-col scroll-reveal-item" style="--sr-delay: 120ms">
    {methodologies.map((m) => (
      <div class="flex-1 max-lg:min-w-[calc(50%-0.625rem)] max-sm:min-w-0 flex flex-col gap-3">
        <div class="methodology-icon text-black" set:html={m.icon} />
        <h3 class="m-0 text-lg font-semibold leading-6 text-black">{m.title}</h3>
        <p class="m-0 text-lg leading-6 text-black">
          {m.description.split('\n\n').map((para, i) => (
            <span class="para-block">{para}{i < m.description.split('\n\n').length - 1 && <><br /><br /></>}</span>
          ))}
        </p>
      </div>
    ))}
  </div>
</section>

