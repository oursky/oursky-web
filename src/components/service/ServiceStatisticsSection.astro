---
/**
 * ServiceStatisticsSection — 3-column statistics grid for /service/* inner pages.
 * Webflow ref: .statistics-container
 * Animated counters driven by data-count attribute and IntersectionObserver in the page script.
 */
interface Stat {
  icon: string;
  number: string;
  dataCount: number;
  title: string;
}
interface Props {
  stats: Stat[];
}
const { stats } = Astro.props;
---

<section class="w-full" aria-label="Statistics">
  <div
    class="statistics-container scroll-reveal-group grid grid-cols-3 gap-y-[3.75rem] mt-5 p-10 max-md:grid-cols-2 max-md:p-4"
    aria-label="Key statistics"
  >
    {stats.map((stat) => (
      <div class="statistics scroll-reveal-item flex flex-col items-center gap-2 text-center">
        <div class="flex justify-center items-center" set:html={stat.icon} />
        <p
          class="statistics__number m-0 text-[2.625rem] font-medium leading-[3.75rem] text-black"
          data-count={stat.dataCount}
        >
          {stat.number}
        </p>
        <p class="m-0 text-lg font-normal leading-6 text-black" set:html={stat.title} />
      </div>
    ))}
  </div>
</section>
