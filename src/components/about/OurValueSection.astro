---

<section class="w-full" aria-label="Why Oursky">
  <!-- Two-card row -->
  <div class="scroll-reveal-group flex flex-row gap-5 mb-[6.25rem] max-md:flex-col max-md:mb-10">
    <!-- Motto card (gray-blue) -->
    <div class="scroll-reveal-item flex-1 rounded-lg p-[3rem_2.44rem] max-md:px-5 max-md:pt-8 max-md:pb-10 bg-section-gray-blue flex flex-col gap-10 max-md:gap-6" style="--sr-delay: 0ms">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" width="52" height="52" fill="currentColor" aria-hidden="true">
        <path d="M32 0H48h80 16V16 144h64 16v16 16h48V80 64h16 80 16V80 224v16V352c0 88.4-71.6 160-160 160H160C71.6 512 0 440.4 0 352V256 240H16 32V16 0zM224 208l0 32v16l0 16 0 48h48V240 208H224zm-32 64l0 0H144v0H112v0H32v80c0 70.7 57.3 128 128 128h64c70.7 0 128-57.3 128-128V240 224 96H304v80 16 48 96 16H288 224 208 192 112 96V320h16 80l0-48zm-80-32V160 144 32H64V240h48zm32 0h48V192 176H144v64z"/>
      </svg>
      <h2 class="m-0 text-6xl font-normal leading-hero text-black max-md:text-hero-secondary max-md:leading-hero-sm">All we care is the<br />Code and UX</h2>
    </div>

    <!-- Why Oursky card (blue) -->
    <div class="scroll-reveal-item flex-1 rounded-lg p-[3rem_2.44rem] max-md:px-5 max-md:pt-8 max-md:pb-10 bg-section-blue-dark flex flex-col gap-10 max-md:gap-6" style="--sr-delay: 80ms">
      <div>
        <h2 class="text-white whitespace-nowrap m-0 text-[18px] font-black leading-[24px]">WHY OURSKY?</h2>
        <p class="text-white mt-10 m-0 text-lg font-normal leading-[24px]">
          Since 2009, we have been providing quality custom software development for a variety of platforms and industries.
          <br /><br />
          Our global team of 70 makers, create apps, design and custom software for our clients, from Apple App of the Years startups to NASDAQ listed companies.
          <br /><br />
          We have a dynamic, open, and respectful culture that encourages people to bring their whole self to their work.
          <br /><br />
          What's your next big idea?
        </p>
      </div>
    </div>
  </div>

  <!-- Statistics grid -->
  <div class="statistics-container scroll-reveal-group grid grid-cols-3 gap-y-[3.75rem] mt-5 p-10 max-md:grid-cols-2 max-md:p-4" aria-label="Company statistics">
    {stats.map((stat) => (
      <div class="statistics scroll-reveal-item flex flex-col items-center gap-2">
        <div class="flex justify-center items-center" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" height="48" width="48" viewBox={stat.viewBox}>
            <path fill={stat.color} fill-rule="evenodd" d={stat.icon} />
          </svg>
        </div>
        <p class="statistics__number m-0 text-[2.625rem] font-medium leading-[3.75rem] text-center" data-count={stat.count}>{stat.number}</p>
        <p class="m-0 text-lg font-normal leading-6 text-center">
          {stat.title}
          {stat.subtitle && <><br /><span class="text-sm">{stat.subtitle}</span></>}
        </p>
      </div>
    ))}
  </div>
</section>
