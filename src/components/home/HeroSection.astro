<!-- Mirrors Webflow .hero-banner-static: light beige card, video at bottom, gradient headline -->
<div class="hero-banner-static flex flex-col justify-start items-stretch w-full relative overflow-hidden bg-hero-beige-light rounded-xl">
  <!-- Caption: gradient headline + subtitle (site header overlays this card on home) -->
  <div class="hero-caption z-[5] w-full max-w-[90%] relative text-center mx-auto max-md:max-w-[95%]">
    <!-- Gradient text requires -webkit-background-clip which stays in CSS -->
    <h1 class="hero-h1 font-[Borna,sans-serif] font-medium mb-0">
      Build it right<br />the First Time
    </h1>
    <p class="hero-subtitle font-[Borna,sans-serif] font-normal text-black mb-0 md:mb-8">
      Engineering Excellence is the<br />baseline here.
    </p>
  </div>

  <!-- Video block anchored to bottom of hero -->
  <div class="absolute inset-0 z-0 bg-hero-beige w-full h-full overflow-hidden" aria-hidden="true">
    <div id="hero-parallax-layer" class="absolute inset-auto left-0 right-0 bottom-0 w-full">
      <div class="hero-video-root relative z-0 w-full overflow-hidden">
        <video
          class="absolute inset-0 w-full h-full object-cover object-center block"
          autoplay
          loop
          muted
          playsinline
          poster="/videos/202604091506-6_poster.0000000.jpg"
        >
          <source src="/videos/202604091506-6_mp4.mp4" type="video/mp4" />
          <source src="/videos/202604091506-6_webm.webm" type="video/webm" />
        </video>
      </div>
      <!-- Gradient fade from beige into transparent, overlapping the video top edge -->
      <div class="hero-gradient absolute w-full pointer-events-none z-[1]" aria-hidden="true"></div>
    </div>
  </div>
</div>

<style>
  /*
   * Hero banner — mirrors Webflow .hero-banner-static (max-height 920px, 140vh cap).
   * Video layer fills card like .hero-banner__img (absolute inset 0).
   */
  .hero-banner-static {
    height: max(500px, min(140vh, 920px));
    min-height: 500px;
    max-height: 920px;
  }

  /* Caption — tight under header; modest pad before video */
  .hero-caption {
    padding-top: clamp(0.65rem, 1.75vw, 1.35rem);
    padding-bottom: clamp(0.75rem, 1.75vw, 1.5rem);
  }

  /* Home: global header is absolutely positioned over the card — reserve vertical band */
  :global(body.page--home) .hero-caption {
    padding-top: clamp(3.1rem, 15vw, 4.75rem);
  }

  /*
   * Gradient text fill — requires webkit-specific properties.
   * font-size also uses clamp for responsive scaling.
   */
  .hero-h1 {
    color: var(--color-nav-active-from);
    -webkit-text-fill-color: transparent;
    background-image: var(--gradient-hero-text);
    -webkit-background-clip: text;
    background-clip: text;
    font-size: var(--text-hero-primary);
    line-height: var(--text-hero-primary);
    letter-spacing: 0;
    white-space: pre;
  }

  .hero-subtitle {
    font-size: var(--text-hero-secondary);
    line-height: 3rem;
    white-space: pre;
  }

  /* Tablet (md–lg): tuck subhead toward the two-line hero (line boxes leave slack below h1) */
  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-subtitle {
      margin-top: -0.45rem;
    }
  }

  /* Desktop: a bit more pull-up vs tablet (larger display type) */
  @media (min-width: 1024px) {
    .hero-subtitle {
      margin-top: -0.85rem;
    }
  }

  /* Video band — taller on large viewports so hero matches live proportions */
  .hero-video-root {
    min-height: clamp(312px, 43.2vh, 576px);
  }

  /* Gradient overlay — complex multi-stop with alpha, overlaps top of video */
  .hero-gradient {
    background-image: linear-gradient(#ecebe7 11%, #ecebe7c2 31%, #e6e5e300);
    height: 260px;
    inset: -1px 0 auto;
  }

  #hero-parallax-layer {
    will-change: transform;
  }

  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-h1 {
    animation: hero-fade-up 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.05s both;
  }

  .hero-subtitle {
    animation: hero-fade-up 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.28s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-h1, .hero-subtitle { animation: none; }
  }

  /* Desktop: headline block close under nav; taller video slice */
  @media (min-width: 1024px) {
    .hero-caption {
      padding-top: clamp(0.35rem, 0.85vw, 1rem);
      padding-bottom: clamp(1rem, 1.5vw, 1.75rem);
    }

    :global(body.page--home) .hero-caption {
      padding-top: clamp(3.35rem, 7vw, 5.1rem);
    }

    .hero-video-root {
      min-height: clamp(400px, 52vh, 640px);
    }

    .hero-gradient {
      height: 280px;
    }
  }

  /* Tablet — Webflow uses ~820px hero height in991 breakpoint for static hero */
  @media (max-width: 1023px) {
    .hero-banner-static {
      height: max(480px, min(105vh, 820px));
      max-height: 820px;
    }
    .hero-caption {
      padding-top: clamp(0.5rem, 1.5vw, 1.25rem);
      padding-bottom: clamp(0.65rem, 1.5vw, 1.35rem);
    }

    :global(body.page--home) .hero-caption {
      padding-top: clamp(3rem, 11vw, 4.35rem);
    }
    .hero-h1 { font-size: 3.5rem; line-height: 3.75rem; }
    .hero-subtitle { font-size: 1.75rem; line-height: 2.25rem; }
    .hero-gradient { height: 200px; }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .hero-banner-static {
      border-radius: var(--radius-lg);
      height: min(92vh, 720px);
      max-height: none;
    }

    /* Full-bleed top/sides; keep bottom corners like other home cards */
    :global(body.page--home) .hero-banner-static {
      border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    }
    .hero-caption {
      padding-top: clamp(0.45rem, 2vw, 1rem);
      padding-bottom: 0.85rem;
    }

    :global(body.page--home) .hero-caption {
      /* Extra air under the fixed header + before the gradient headline */
      padding-top: clamp(4.75rem, 26vw, 6.5rem);
      /* A bit more room before the video band under the subhead */
      padding-bottom: 1.125rem;
    }
    .hero-h1 {
      font-size: var(--text-hero-secondary);
      line-height: 2.75rem;
      white-space: normal;
      margin-bottom: 1.125rem;
    }
    .hero-subtitle { font-size: var(--text-lg); line-height: 1.75rem; white-space: normal; }
    .hero-video-root { min-height: clamp(240px, 48vh, 408px); }
    .hero-gradient { height: 180px; }
  }
</style>

<script>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const layer = document.getElementById('hero-parallax-layer');
    if (!layer) return;

    const FACTOR = 0.35;
    let raf = 0;

    function update() {
      layer.style.transform = `translateY(${window.scrollY * FACTOR}px)`;
      raf = 0;
    }

    window.addEventListener('scroll', () => {
      if (!raf) raf = requestAnimationFrame(update);
    }, { passive: true });
  })();
</script>
