---

<div class="flex flex-col gap-[3.75rem]">
  <!-- Blue intro card -->
  <section class="scroll-reveal-group w-full" aria-label="About our UI/UX design">
    <div class="bg-section-blue rounded-lg px-8 pt-[2.8rem] pb-14 max-md:px-5 max-md:pt-8 max-md:pb-10 flex flex-row gap-16 items-center max-lg:flex-col max-lg:gap-8 max-md:gap-6 scroll-reveal-item" style="--sr-delay: 0ms">
      <div
        class="flex size-24 shrink-0 items-center justify-center self-center overflow-hidden rounded-full bg-white sm:max-lg:size-32 min-lg:size-40"
      >
        <!-- compass-drafting — FA Sharp Light, path from ref/fontawesome-pro-6.5.1-desktop/svgs/sharp-light/compass-drafting.svg -->
        <svg
          class="size-[4.5rem] object-contain sm:max-lg:size-28 min-lg:size-32"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 512 512"
          fill="black"
          aria-hidden="true"
        >
          <path
            d="M282.3 154.3l-.2-.3 13-7.4c15.1-11.7 24.8-30 24.8-50.6c0-35.3-28.7-64-64-64s-64 28.7-64 64c0 20.6 9.7 38.9 24.8 50.6l13 7.4-.2 .3c8 3.6 17 5.7 26.3 5.7s18.3-2 26.3-5.7zm15.9 27.9c-12.8 6.3-27.1 9.8-42.3 9.8s-29.5-3.5-42.3-9.8L142.2 307.4C176.1 325.6 214.8 336 256 336c88.8 0 166.4-48.2 207.9-120l27.7 16c-47 81.3-134.9 136-235.6 136c-47 0-91.1-11.9-129.7-32.8L29.9 503.9 2.1 488.1l97-169.8c-32.1-22.7-59-52.1-78.7-86.2l27.7-16c16.9 29.2 39.8 54.6 67 74.3l72.5-126.9C170.5 146.1 160 122.3 160 96c0-53 43-96 96-96s96 43 96 96c0 26.3-10.5 50.1-27.6 67.4l56.5 98.9c-8.5 6.4-17.5 12.2-27 17.2l-55.6-97.4zM482.1 503.9L401.5 363c9.4-5.1 18.5-10.7 27.2-16.8l81.1 141.9-27.8 15.9z"
          />
        </svg>
      </div>
      <div class="flex-1 scroll-reveal-item" style="--sr-delay: 80ms">
        <p class="m-0 text-white text-lg leading-8">
          User experience (UX) is about the interaction between you and your customers. Our design process involves
          understanding your audience and researching the user preferences, digital habits, and behaviors to map out
          user journeys and create user personas and scenarios. Apart from visualizing UX flows and architectures,
          we also advise on the technologies available for your project (including their trade-offs) to anticipate
          and clear development bottlenecks.
        </p>
      </div>
    </div>
  </section>

  <!-- Approach items -->
  <section class="scroll-reveal-group w-full" aria-label="Our design approach">
    <div class="flex flex-wrap gap-8 max-md:gap-10 max-sm:gap-10 max-sm:flex-col scroll-reveal-item" style="--sr-delay: 0ms">
      {approachItems.map((item) => (
        <div class="flex-1 min-w-[200px] max-sm:min-w-0 flex flex-col gap-3">
          <div class="text-black" set:html={item.icon} />
          <h3 class="m-0 text-lg font-bold text-black leading-6">{item.title}</h3>
          <p class="m-0 text-base leading-[1.2rem] text-black">{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Statistics -->
  <ServiceStatisticsSection stats={stats} />

  <!-- Dark design process section -->
  <section class="scroll-reveal-group w-full" aria-label="How we turn ideas into digital products">
    <div class="bg-[#232833] rounded-lg px-8 pt-[2.8rem] pb-14 flex flex-col gap-10 scroll-reveal-item" style="--sr-delay: 0ms">
      <p class="m-0 text-white text-2xl font-bold text-center leading-10">How we turn ideas into a complete digital product</p>
      <div class="design-process-grid grid grid-cols-3 gap-8 max-md:grid-cols-2 max-sm:grid-cols-1 scroll-reveal-item" style="--sr-delay: 80ms">
        {designProcess.map((step) => (
          <div class="flex flex-col items-center gap-2 text-center text-white">
            <div set:html={step.icon} />
            <h3 class="m-0 text-base font-bold leading-5">{step.title}</h3>
            <p class="m-0 text-[11px] leading-[14px] opacity-80">
              {step.bullets.split('\n').map((line, j, arr) => (
                <span>{line}{j < arr.length - 1 && <br />}</span>
              ))}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Shared "why Oursky" methodologies -->
  <ServiceSharedMethodologies />
</div>
