---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BlogCard from './BlogCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
const allCategories = await getCollection('categories');
const categoryNameBySlug = new Map(allCategories.map((c) => [c.data.slug, c.data.name]));
const listLabel = (slugs: string[], display?: string) => {
  if (display) return display;
  if (!slugs.length) return '';
  return slugs
    .map((s) => categoryNameBySlug.get(s) ?? s)
    .filter(Boolean)
    .join(' · ');
};
---

{
  posts.length === 0 ? (
    <p class="text-text-muted">No posts to show.</p>
  ) : (
    <ul class="scroll-reveal-group grid gap-6 sm:grid-cols-2 list-none p-0 m-0">
      {posts.map((post, i) => {
        const pillSlugs = post.data.tags.length > 0 ? post.data.tags : post.data.categories;
        const pills = pillSlugs.map((slug) => ({
          slug,
          label: categoryNameBySlug.get(slug) ?? slug,
        }));
        const topLabel = listLabel(post.data.categories, post.data.displayCategory);
        return (
          <li class="scroll-reveal-item flex" style={`--sr-delay: ${(i % 2) * 80}ms`}>
            <BlogCard post={post} topLabel={topLabel} pills={pills} dropTitleMinHOnMobile />
          </li>
        );
      })}
    </ul>
  )
}
