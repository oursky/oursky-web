---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Thoughts on software engineering, product design, and building remarkable digital products from the Oursky team."
>
  <main class="max-w-[var(--max-w-content)] mx-auto px-[var(--spacing-page-x)] lg:px-[var(--spacing-page-x-lg)] py-16">
    <header class="mb-12">
      <h1 class="text-4xl lg:text-5xl font-bold mb-4">Blog</h1>
      <p class="text-xl text-[var(--color-brand-gray-700)]">
        Engineering, design, and product insights from the Oursky team.
      </p>
    </header>

    {
      allPosts.length === 0 ? (
        <p class="text-[var(--color-brand-gray-500)]">
          Posts are being imported — check back soon.
        </p>
      ) : (
        <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {allPosts.map((post) => (
            <li>
              <a href={`/blogs/${post.id}`} class="group block">
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt ?? post.data.title}
                    class="w-full aspect-video object-cover rounded-lg mb-4 group-hover:opacity-90 transition-opacity"
                    loading="lazy"
                  />
                )}
                <a
                  href={`/blog-category/${post.data.category}`}
                  class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-primary)] hover:underline mb-2 block"
                >
                  {post.data.category}
                </a>
                <h2 class="text-xl font-bold leading-snug group-hover:text-[var(--color-brand-primary)] transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-[var(--color-brand-gray-500)] text-sm mt-2">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>
