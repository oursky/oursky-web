---
/**
 * ContactForm — reusable contact form fields.
 *
 * Renders the "Contacts" heading, Name/Company/Email/Message inputs,
 * and the "Let's Talk" amber submit button.
 * No wrapping layout or dark banner — those belong to the parent section.
 *
 * Form action is deferred to Phase 4/5 (backend integration).
 */
---

<form class="flex flex-col gap-3.5" name="Contact us form" method="post" action="/contact">
  <h2 class="text-xl font-bold text-black mb-2">Contacts</h2>

  <div class="grid grid-cols-2 max-[599px]:grid-cols-1 gap-3">
    <div class="flex flex-col">
      <label for="contact-name" class="sr-only">Name</label>
      <input
        id="contact-name"
        type="text"
        name="name"
        class="w-full px-4 py-3 border border-border rounded-md bg-input text-sm text-text outline-none transition-colors focus:border-primary box-border"
        placeholder="Name"
        autocomplete="name"
      />
    </div>
    <div class="flex flex-col">
      <label for="contact-company" class="sr-only">Company</label>
      <input
        id="contact-company"
        type="text"
        name="company"
        class="w-full px-4 py-3 border border-border rounded-md bg-input text-sm text-text outline-none transition-colors focus:border-primary box-border"
        placeholder="Company"
        autocomplete="organization"
      />
    </div>
  </div>

  <div class="flex flex-col">
    <label for="contact-email" class="sr-only">Email</label>
    <input
      id="contact-email"
      type="email"
      name="email"
      class="w-full px-4 py-3 border border-border rounded-md bg-input text-sm text-text outline-none transition-colors focus:border-primary box-border"
      placeholder="Email"
      autocomplete="email"
      required
    />
  </div>

  <div class="flex flex-col">
    <label for="contact-message" class="sr-only">Message</label>
    <textarea
      id="contact-message"
      name="message"
      class="w-full px-4 py-3 border border-border rounded-md bg-input text-sm text-text outline-none transition-colors focus:border-primary box-border resize-y min-h-28"
      rows="4"
      placeholder="Tell us about your project..."
    ></textarea>
  </div>

  <button
    type="submit"
    class="self-start px-9 py-3.5 bg-primary-dark text-black rounded-full text-sm font-bold cursor-pointer transition-all hover:scale-[1.03] hover:shadow-[0_4px_12px_rgba(255,187,85,0.4)]"
  >
    Let's Talk
  </button>
</form>
