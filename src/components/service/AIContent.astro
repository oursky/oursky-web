    number: '50+',
    dataCount: 50,
    title: 'Products shipped with deep knowledge in software architecture and design',
  },
  {
    icon: `<svg width="49" height="49" viewBox="0 0 49 49" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M31.4688 14.4283L30.25 9.83459L25.6562 8.61584C25.2812 8.42834 25 8.05334 25 7.58459C25 7.20959 25.2812 6.83459 25.6562 6.64709L30.25 5.33459L31.4688 0.834595C31.6562 0.459595 32.0312 0.0845947 32.5 0.0845947C32.875 0.0845947 33.25 0.459595 33.4375 0.834595L34.75 5.33459L39.25 6.64709C39.625 6.83459 40 7.20959 40 7.58459C40 8.05334 39.625 8.42834 39.25 8.61584L34.75 9.83459L33.4375 14.4283C33.25 14.8033 32.875 15.0846 32.5 15.0846C32.0312 15.0846 31.6562 14.8033 31.4688 14.4283ZM20.9688 14.8971L25.2812 23.7096L35.0312 25.1158C36.8125 25.3971 37.5625 27.6471 36.25 28.9596L29.2188 35.8033L30.9062 45.4596C31.1875 47.3346 29.3125 48.7408 27.625 47.8971L18.9062 43.3033L10.2812 47.8971C8.59375 48.7408 6.71875 47.3346 7 45.4596L8.6875 35.8033L1.65625 28.9596C0.34375 27.6471 1 25.3971 2.875 25.1158L12.625 23.7096L16.9375 14.8971C17.7812 13.2096 20.125 13.2096 20.9688 14.8971ZM41.125 22.9596L37.5625 21.9283C37.1875 21.8346 37 21.4596 37 21.0846C37 20.8033 37.1875 20.4283 37.5625 20.3346L41.125 19.3033L42.1562 15.7408C42.25 15.3658 42.625 15.0846 43 15.0846C43.2812 15.0846 43.6562 15.3658 43.75 15.7408L44.7812 19.3033L48.3438 20.3346C48.7188 20.4283 49 20.8033 49 21.0846C49 21.4596 48.7188 21.8346 48.3438 21.9283L44.7812 22.9596L43.75 26.5221C43.6562 26.8971 43.2812 27.0846 43 27.0846C42.625 27.0846 42.25 26.8971 42.1562 26.5221L41.125 22.9596Z" fill="#FBBC05"/></svg>`,
