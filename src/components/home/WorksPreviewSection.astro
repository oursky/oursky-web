---
import PillButton from '../ui/PillButton.astro';
---

<section class="works-section scroll-reveal-group w-full min-h-[640px] max-lg:min-h-[860px] max-md:min-h-[840px] py-28 pb-section-lg max-md:py-16 max-md:pb-20" aria-labelledby="works-heading">
  <div class="flex justify-center items-center w-full max-w-[1360px] mx-auto px-16 box-border max-lg:flex-col max-lg:gap-8 max-md:px-8">
    <!-- Text column -->
    <div class="flex flex-col justify-center items-start w-1/2 max-lg:w-full">
      <h2 id="works-heading" class="scroll-reveal-item text-white text-3xl font-semibold leading-[3.5rem] mb-4" style="--sr-delay: 0ms">
        Our Works
      </h2>
      <p
        class="scroll-reveal-item text-white text-[1.6rem] font-normal leading-8 mb-6 max-md:text-lg max-md:leading-[1.65rem]"
        style="--sr-delay: 70ms"
      >
        We develop and design mobile and web apps, or native softwares for our clients,
        from Apple App of the Years startups to NASDAQ listed enterprises.
      </p>
      <PillButton
        href="/works/"
        label="View Our Works"
        variant="secondary"
        onDark
        class="scroll-reveal-item my-2.5"
      />
    </div>
    <!-- Right spacer: keeps text pinned left on desktop, hidden on tablet/mobile -->
    <div class="w-1/2 max-lg:hidden" aria-hidden="true"></div>
  </div>

  <!-- Phone group: always absolute bottom-right, bleeds off right + bottom edges -->
  <div class="works-cardwrap" aria-hidden="true">
    <img class="works-card works-card--1" src="/images/swrm-preview-phone.webp" alt="" loading="lazy" />
    <img class="works-card works-card--2" src="/images/pl-preview-phone.webp" alt="" loading="lazy" />
    <img class="works-card works-card--3" src="/images/jp-preview-phone.webp" alt="" loading="lazy" />
  </div>
</section>

<style>
  .works-section {
    background-color: #00aeff;
    background-image: linear-gradient(120deg, #42afb9 17%, #0095ff 52%, #2b5ef8 81%);
    overflow-x: clip;
    position: relative;
  }

  .works-card {
    position: absolute;
    display: block;
    filter: drop-shadow(0 6px 16px rgba(0, 0, 0, 0.14));
  }

  /* ── Desktop (≥1024px) ── */
  .works-cardwrap {
    position: absolute;
    overflow: visible;
    will-change: transform;
    bottom: -120px;
    right: -60px;
    width: 630px;
    height: 654px;
  }

  .works-card--1 { width: 336px; z-index: 3; left: 289px; top: 44px;  transform: rotate(13.38deg); }
  .works-card--2 { width: 366px; z-index: 2; left: 17px;  top: 0;     transform: rotate(13.38deg); }
  .works-card--3 { width: 338px; z-index: 1; left: 0;     top: 282px; transform: rotate(13.38deg); }

  /* ── Tablet (768–1023px) — 25% larger ── */
  @media (min-width: 768px) and (max-width: 1023px) {
    .works-cardwrap { bottom: -60px; right: -40px; width: 519px; height: 538px; }
    .works-card--1 { width: 276px; left: 238px; top: 36px;  }
    .works-card--2 { width: 301px; left: 15px;  top: 0;     }
    .works-card--3 { width: 278px; left: 0;     top: 233px; }
  }

  /* ── Mobile (≤767px): large tight cluster, bottom-right, heavy crop ── */
  @media (max-width: 767px) {
    .works-cardwrap { right: -80px; width: 560px; height: 580px; bottom: -120px; }
    .works-card--1 { width: 300px; left: 255px; top: 38px;  }
    .works-card--2 { width: 325px; left: 14px;  top: 0;     }
    .works-card--3 { width: 300px; left: 0;     top: 250px; }
  }
</style>

<script>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const section = document.querySelector('.works-section');
    const cardwrap = section?.querySelector<HTMLElement>('.works-cardwrap');
    if (!section || !cardwrap) return;

    const FACTOR = 0.12;
    let raf = 0;

    function update() {
      const rect = section.getBoundingClientRect();
      const offset = (window.innerHeight / 2 - (rect.top + rect.height / 2)) * FACTOR;
      cardwrap.style.transform = `translateY(${-offset}px)`;
      raf = 0;
    }

    window.addEventListener('scroll', () => {
      if (!raf) raf = requestAnimationFrame(update);
    }, { passive: true });

    update();
  })();
</script>
