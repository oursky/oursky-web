---
/**
 * ContactForm — reusable contact form fields.
 *
 * Renders Name/Company/Email/Message inputs + "Let's Talk" submit button.
 * "Contacts" heading only shown when `showHeading` is true (home CTA).
 * No wrapping layout or dark banner — those belong to the parent section.
 *
 * Form action is deferred to Phase 4/5 (backend integration).
 */
import PillButton from './PillButton.astro';

interface Props {
  showHeading?: boolean;
}
const { showHeading = false } = Astro.props;
---

<form class="flex flex-col gap-3.5" name="Contact us form" method="post" action="/contact">
  {showHeading && <h2 class="text-xl font-bold text-black mb-2">Contacts</h2>}

  <div class="grid grid-cols-2 max-[599px]:grid-cols-1 gap-3">
    <div class="flex flex-col">
      <label for="contact-name" class="sr-only">Name</label>
      <input
        id="contact-name"
        type="text"
        name="name"
        class="w-full px-4 py-[1.1rem] rounded-md bg-black/5 text-base text-text outline-none transition-colors focus:bg-black/10 box-border placeholder:text-text-muted"
        placeholder="Name"
        autocomplete="name"
      />
    </div>
    <div class="flex flex-col">
      <label for="contact-company" class="sr-only">Company</label>
      <input
        id="contact-company"
        type="text"
        name="company"
        class="w-full px-4 py-[1.1rem] rounded-md bg-black/5 text-base text-text outline-none transition-colors focus:bg-black/10 box-border placeholder:text-text-muted"
        placeholder="Company"
        autocomplete="organization"
      />
    </div>
  </div>

  <div class="flex flex-col">
    <label for="contact-email" class="sr-only">Email</label>
    <input
      id="contact-email"
      type="email"
      name="email"
      class="w-full px-4 py-[1.1rem] rounded-md bg-black/5 text-base text-text outline-none transition-colors focus:bg-black/10 box-border placeholder:text-text-muted"
      placeholder="Email"
      autocomplete="email"
      required
    />
  </div>

  <div class="flex flex-col">
    <label for="contact-message" class="sr-only">Message</label>
    <textarea
      id="contact-message"
      name="message"
      class="w-full px-4 py-[1.1rem] rounded-md bg-black/5 text-base text-text outline-none transition-colors focus:bg-black/10 box-border resize-y min-h-[11rem]"
      rows="4"
      placeholder="Your Message"
    ></textarea>
  </div>

  <PillButton type="submit" label="Let's Talk" variant="primary" class="self-start" />
</form>
