---
---

<!-- Blue gradient section with rounded top corners and 3D card transforms -->
<section class="works-section scroll-reveal-group w-full min-h-[500px] py-20 pb-[120px] max-md:py-12 max-md:pb-16" aria-labelledby="works-heading">
  <div class="flex justify-center items-center w-full max-w-[1360px] mx-auto px-10 box-border max-[991px]:flex-col max-[991px]:gap-8 max-md:px-5">
    <!-- Text column -->
    <div class="flex flex-col justify-center items-start w-1/2 max-[991px]:w-full">
      <h2 id="works-heading" class="scroll-reveal-item text-white text-3xl font-semibold leading-[3.5rem] mb-4" style="--sr-delay: 0ms">
        Our Works
      </h2>
      <p
        class="scroll-reveal-item text-white text-[1.6rem] font-normal leading-8 mb-6 max-md:text-lg max-md:leading-[1.65rem]"
        style="--sr-delay: 70ms"
      >
        We develop and design mobile and web apps, or native softwares for our clients,
        from Apple App of the Years startups to NASDAQ listed enterprises.
      </p>
      <a
        href="/works"
        class="scroll-reveal-item inline-block no-underline text-white border border-white rounded-[6.25rem] px-[3.125rem] py-4 text-lg font-medium leading-9 my-2.5 hover:opacity-60 transition-opacity"
        style="--sr-delay: 140ms"
      >
        View Our Works
      </a>
    </div>

    <!-- 3D card stack — transforms require CSS -->
    <div
      class="scroll-reveal-item flex justify-center items-center w-1/2 text-center max-[991px]:w-full max-[991px]:h-[340px] max-md:h-[260px]"
      style="--sr-delay: 200ms"
      aria-hidden="true"
    >
      <div class="works-cardwrap">
        <div class="works-card works-card--1"></div>
        <div class="works-card works-card--2"></div>
        <div class="works-card works-card--3"></div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Blue gradient + rounded top corners + clip-path (3D overflow fix) — no Tailwind equivalent */
  .works-section {
    background-color: #00aeff;
    background-image: linear-gradient(120deg, #42afb9 17%, #0095ff 52%, #2b5ef8 81%);
    border-top-left-radius: 40px;
    border-top-right-radius: 40px;
    clip-path: inset(0 0 0 0 round 40px 40px 0 0);
    /* 3D card transforms use large translate(); visible overflow widens the whole page */
    overflow-x: clip;
  }

  @media (max-width: 767px) {
    .works-section {
      border-radius: 2rem 2rem 0 0;
      clip-path: inset(0 0 0 0 round 2rem 2rem 0 0);
    }
  }

  /* 3D card container (overflow clipped at .works-section so transforms don’t widen the page) */
  .works-cardwrap {
    aspect-ratio: 2 / 3;
    width: 280px;
    position: relative;
    overflow: visible;
  }

  /* Shared card base — 3D transform-style required for perspective */
  .works-card {
    aspect-ratio: 2 / 3;
    width: 280px;
    transform-style: preserve-3d;
    background-position: 50%;
    background-size: cover;
    border-radius: 36px;
    position: absolute;
  }

  /* Individual card transforms — exact rotateX/rotateZ values from Webflow */
  .works-card--1 {
    z-index: 3;
    background-color: #00973d;
    background-image: url('/images/swrm-preview-phone.png');
    transform: rotateX(45deg) rotateY(0) rotateZ(45deg) translate(360px, -60px);
  }

  .works-card--2 {
    z-index: 2;
    background-color: #242a34;
    background-image: url('/images/pl-preview-phone.png');
    transform: rotateX(45deg) rotateY(0) rotateZ(45deg) translate(47px, -61px);
  }

  .works-card--3 {
    z-index: 1;
    background-color: #222;
    background-image: url('/images/jp-preview-phone.png');
    transform: rotateX(45deg) rotateY(0) rotateZ(45deg) translate(220px, 388px);
  }

  @media (max-width: 767px) {
    .works-cardwrap,
    .works-card {
      width: 180px;
    }

    .works-card--1 { transform: rotateX(45deg) rotateY(0) rotateZ(45deg) translate(220px, -40px); }
    .works-card--2 { transform: rotateX(45deg) rotateY(0) rotateZ(45deg) translate(30px, -40px); }
    .works-card--3 { transform: rotateX(45deg) rotateY(0) rotateZ(45deg) translate(140px, 240px); }
  }
</style>
