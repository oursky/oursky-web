# Webflow Data API token – used during migration extraction only.
# Obtain from: Webflow Dashboard → Site Settings → Apps & Integrations → API Access
# Required scope: cms:read, pages:read, sites:read
WEBFLOW_API_TOKEN=your_token_here

# Webflow Site ID – found in Site Settings or returned by data_sites_tool
WEBFLOW_SITE_ID=your_site_id_here

# ── Analytics (Phase 5 — set before go-live) ────────────────────────────────
# Plausible Analytics — privacy-friendly, cookieless, no consent banner needed.
# https://plausible.io/
#
# The Plausible script is only emitted when:
#   1. PLAUSIBLE_DOMAIN is set, AND
#   2. the build runs in production mode (`astro build` with import.meta.env.PROD).
# Set this in Netlify under Site → Environment variables, scoped to the
# **Production** deploy context, so deploy previews and branch deploys don't
# pollute the live dashboard.
PLAUSIBLE_DOMAIN=oursky.com

# ── Site configuration ───────────────────────────────────────────────────────
# Optional override for canonical / sitemap / OG base URL (no trailing slash).
# On Netlify: deploy previews use DEPLOY_PRIME_URL automatically; production
# (CONTEXT=production) defaults to https://www.oursky.com unless you set this
# (e.g. custom production hostname).
PUBLIC_SITE_URL=https://www.oursky.com
