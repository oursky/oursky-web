---
/**
 * ContactCtaSection — "How can we help?" two-column section.
 *
 * Webflow: .contact-us div inside .section__home__lastsection
 * Visual:
 *   Left column (dark, ~35%): "How can we help?" heading, email link, 3D wireframe grid
 *   Right column (light, ~65%): ContactForm component
 */
import ContactForm from '../ui/ContactForm.astro';
---

<div class="scroll-reveal-group grid [grid-template-columns:2fr_3fr] rounded-lg overflow-hidden min-h-[26rem] max-lg:grid-cols-1">
  <!-- Banner side (left) -->
  <div class="bg-black p-10 max-md:px-5 max-md:pt-8 max-md:pb-10 flex flex-col gap-3 bg-[url('/images/os-w-4.svg')] bg-center bg-no-repeat bg-auto">
    <h2 class="scroll-reveal-item text-2xl font-bold leading-footer text-white m-0" style="--sr-delay: 0ms">How can we help?</h2>
    <p class="scroll-reveal-item m-0" style="--sr-delay: 55ms">
      <a
        href="mailto:hello@oursky.com"
        class="text-2xl font-normal leading-footer text-white no-underline transition-opacity hover:opacity-75 hover:underline"
      >
        hello@oursky.com
      </a>
    </p>
  </div>

  <!-- Form side (right) -->
  <div class="scroll-reveal-item bg-surface p-10 max-md:px-5 max-md:pt-8 max-md:pb-10 flex flex-col gap-5" style="--sr-delay: 95ms">
    <ContactForm showHeading />
  </div>
</div>

